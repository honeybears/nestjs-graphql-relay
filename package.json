  "description": "NestJS library for implementing the Relay specification with the GraphQL code-first approach",
  "devDependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@eslint/js": "^10.0.1",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/common": "^11.1.14",
    "@nestjs/core": "^11.1.14",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/testing": "^11.1.14",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.1",
    "@types/supertest": "^7.2.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "graphql": "^16.13.0",
    "jest": "^30.2.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/graphql": "^12.0.0",
    "graphql": "^16.0.0",
    "reflect-metadata": "^0.1.13",
    "typescript": "^5.9.3"
  }
